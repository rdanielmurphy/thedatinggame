{
  "expo": {
    "name": "Dating Game",
    "slug": "dating-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#E91E8C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.datinggame.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E91E8C"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.datinggame.app"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E91E8C"
        }
      ]
    ]
  }
}
